# .env.example
# Copy to .env.local for local development. Vite only exposes variables
# prefixed with VITE_ to client-side code — anything without that prefix
# is invisible to import.meta.env and will silently resolve to undefined.

# --- API ---------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_API_TIMEOUT_MS=15000

# --- Auth ----------------------------------------------------------------
VITE_AUTH_TOKEN_STORAGE_KEY=finance_tracker_auth
VITE_AUTH_REFRESH_ENDPOINT=/auth/refresh

# --- Feature Flags ---------------------------------------------------------
# Kept as explicit "true"/"false" strings, never bare booleans — all env
# vars arrive as strings, and env.ts is responsible for coercing them.
VITE_FEATURE_INVESTMENTS_MODULE=false
VITE_FEATURE_MULTI_CURRENCY=true
VITE_FEATURE_EXPORT_PDF=true
VITE_FEATURE_AI_INSIGHTS=false

# --- Defaults ---------------------------------------------------------
VITE_DEFAULT_CURRENCY=INR
VITE_DEFAULT_LOCALE=en-IN

# --- Observability (optional — app must run without these set) ---------
VITE_SENTRY_DSN=
VITE_ANALYTICS_WRITE_KEY=

# --- Build metadata (usually injected by CI, not set manually) ---------
VITE_APP_VERSION=0.1.0
